# ─── MongoDB ─────────────────────────────────────────────────────────────────
# Full connection string from MongoDB Atlas (includes username, password, cluster)
MONGODB_URI=

# ─── Firebase Admin (server-side — do NOT prefix with NEXT_PUBLIC_) ──────────
# Found in Firebase Console → Project Settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the private key with literal \n characters — the code replaces them
FIREBASE_PRIVATE_KEY=

# ─── Firebase Client (public — NEXT_PUBLIC_ prefix required by Next.js) ──────
# Found in Firebase Console → Project Settings → Your apps → Web app config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# ─── Google Cloud / Vertex AI ─────────────────────────────────────────────────
# Project ID in Google Cloud Console
GOOGLE_CLOUD_PROJECT_ID=
# Region where Vertex AI is enabled (us-central1 recommended)
GOOGLE_CLOUD_LOCATION=us-central1
# Service account credentials for Vertex AI (from GCP IAM)
GOOGLE_CLOUD_CLIENT_EMAIL=
# Paste private key with literal \n chars — the code replaces them
GOOGLE_CLOUD_PRIVATE_KEY=
# Gemini model IDs — use these exact values
GEMINI_MODEL_FLASH=gemini-2.0-flash-001
GEMINI_MODEL_PRO=gemini-1.5-pro-001

# ─── Voyage AI (via MongoDB MCP for vector embeddings) ───────────────────────
VOYAGE_API_KEY=

# ─── Upstash Redis (serverless rate limiting) ─────────────────────────────────
# Create a Redis database at upstash.com → copy REST URL and token
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
