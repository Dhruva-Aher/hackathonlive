# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# Full connection string from MongoDB Atlas → Connect → Drivers
# Example: mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/justicequeue
MONGODB_URI=

# ─── Firebase Admin (server-side token verification) ─────────────────────────
# Firebase Console → Project Settings → Service accounts → Generate new private key
# NOTE: JusticeQueue uses manual X.509 cert verification, not the Admin SDK
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the private key with literal \n — the code handles replacement
FIREBASE_PRIVATE_KEY=

# ─── Firebase Client (public — NEXT_PUBLIC_ prefix required by Next.js) ──────
# Firebase Console → Project Settings → Your apps → Web app → Config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# ─── Google Cloud / Vertex AI (Gemini 3.1) ────────────────────────────────────
# OAuth 2.0 credentials — Web application type in GCP Console → APIs → Credentials
# Used to authenticate as an authorized_user (no service account key needed)
# Generate a refresh token via: https://developers.google.com/oauthplayground
#   Scope to authorize: https://www.googleapis.com/auth/cloud-platform
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Gemini model IDs — must match what is available in your GCP project
# Check: GCP Console → Vertex AI → Model Garden → Gemini
GEMINI_MODEL_FLASH=gemini-3.1-flash-lite
GEMINI_MODEL_PRO=gemini-3.1-pro-preview-05-06

# ─── Google Cloud Agent Builder ───────────────────────────────────────────────
# GCP Console → Agent Builder → Apps → your app → Engine ID
# Optional — used to tag agent traces with the engine reference
AGENT_BUILDER_ENGINE_ID=

# ─── Voyage AI (vector embeddings for Atlas $vectorSearch) ───────────────────
# https://www.voyageai.com → API Keys
# Model used: voyage-large-2 (1024 dimensions, cosine similarity)
VOYAGE_API_KEY=

# ─── Upstash Redis (serverless rate limiting) ─────────────────────────────────
# https://console.upstash.com → Create Database → REST API
# Limits: 10 uploads per user per 15 minutes
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
