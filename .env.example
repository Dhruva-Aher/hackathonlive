# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# Full connection string from MongoDB Atlas → Connect → Drivers
# Example: mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/justicequeue
MONGODB_URI=

# ─── Firebase Client config (safe to expose — Firebase restricts by domain) ──
# Firebase Console → Project Settings → Your apps → Web app → SDK setup → Config
# Copy each value from the firebaseConfig object shown in the console.
# NEXT_PUBLIC_ prefix means Next.js embeds these in the browser bundle — correct for Firebase.
# verifyToken.js also uses NEXT_PUBLIC_FIREBASE_PROJECT_ID for JWT audience check.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ─── Google Cloud / Vertex AI (Gemini 3.1) ────────────────────────────────────
# OAuth 2.0 credentials — Web application type in GCP Console → APIs → Credentials
# Used to authenticate as an authorized_user (no service account key needed)
# Generate a refresh token via: https://developers.google.com/oauthplayground
#   Scope to authorize: https://www.googleapis.com/auth/cloud-platform
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Gemini model IDs — must match what is available in your GCP project
# Check: GCP Console → Vertex AI → Model Garden → Gemini
GEMINI_MODEL_FLASH=gemini-3.1-flash-lite
GEMINI_MODEL_PRO=gemini-3.1-pro-preview-05-06

# ─── Google Cloud Agent Builder ───────────────────────────────────────────────
# GCP Console → Agent Builder → Apps → your app → Engine ID
# Optional — used to tag agent traces with the engine reference
AGENT_BUILDER_ENGINE_ID=

# ─── Voyage AI (vector embeddings for Atlas $vectorSearch) ───────────────────
# https://www.voyageai.com → API Keys
# Model used: voyage-large-2 (1024 dimensions, cosine similarity)
VOYAGE_API_KEY=

# ─── Upstash Redis (serverless rate limiting) ─────────────────────────────────
# https://console.upstash.com → Create Database → REST API
# Limits: 10 uploads per user per 15 minutes
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Gmail outreach drafts ────────────────────────────────────────────────────
# Set to true to enable Gmail draft creation via the agent.
# GOOGLE_OAUTH_REFRESH_TOKEN must be regenerated with gmail.compose scope first:
#   1. OAuth Playground → Use your own credentials
#   2. Scopes: https://www.googleapis.com/auth/cloud-platform
#              https://www.googleapis.com/auth/gmail.compose
#              https://www.googleapis.com/auth/calendar.events
#   3. Copy the new refresh_token and update GOOGLE_OAUTH_REFRESH_TOKEN above
GMAIL_ENABLED=true

# ─── Google Calendar blocking ─────────────────────────────────────────────────
# Set to true to enable calendar event creation via the agent.
# Same refresh token scope requirement as GMAIL_ENABLED (see above).
CALENDAR_ENABLED=true
